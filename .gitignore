# =============================================================================
# .gitignore — Files Git Will NEVER Upload to GitHub
# =============================================================================
# CRITICAL: .env contains your secret API key.
# If this gets pushed to GitHub, bots will steal your key within minutes.
# This file prevents that from happening.

# Secret keys — NEVER push this
.env

# Python virtual environment — huge folder, not needed on GitHub
venv/
env/

# Python cache files — auto-generated, not needed
__pycache__/
*.pyc
*.pyo
*.pyd

# ChromaDB database — the actual vector data
# This is generated when someone runs the app with their PDF
# No need to include it in the repo (it's PDF-specific)
chroma_db/

# Temp files
*.tmp
*.log

# macOS system files
.DS_Store

# Windows system files
Thumbs.db
